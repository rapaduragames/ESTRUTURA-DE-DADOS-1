#include <iostream>
#include <string>
#include <algorithm>
using namespace std;



int main() {
	setlocale(LC_ALL, "Portuguese");
    string msg, normal = "", invertida;

    cout << "Digite a mensagem: ";
    getline(cin, msg);

    // Remove espaços e deixa maiusculo 
    for (int i = 0; i < msg.length(); i++) {
        if (msg[i] != ' ') {
            normal += toupper(msg[i]);
        }
    }

    // Inverte
    invertida = normal;
    reverse(invertida.begin(), invertida.end());

    // Verifica
    if (normal == invertida) {
        cout << "É um palíndromo!" << endl;
    } else {
        cout << "Não é um palíndromo." << endl;
    }

    return 0;
}
